{
  "name": "drbalcony/nova-commons",
  "description": "A Laravel package providing common functionalities such as client authentication, exception handling, logging, and JSON response macros.",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "stable",
  "require": {
    "php": "^8.0",
    "laravel/framework": "^10.0|^11.0",
    "illuminate/support": "^10.0|^11.0",
    "illuminate/http": "^10.0|^11.0",
    "illuminate/pagination": "^10.0|^11.0",
    "ext-json": "*",
    "php-amqplib/php-amqplib": "^3.0",
    "guzzlehttp/guzzle": "^7.9"
  },
  "autoload": {
    "psr-4": {
      "DrBalcony\\NovaCommon\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "DrBalcony\\NovaCommon\\Providers\\NovaCommonServiceProvider",
        "DrBalcony\\NovaCommon\\Providers\\ResponseMacroServiceProvider"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "scripts": {
    "test": "src/Providers/vendor/bin/phpunit"
  }
}
